# =============================================
# Voooice Environment Variables
# Copy this file to .env and fill in values
# =============================================

# --- Frontend (Vite) ---
# Local TTS server URL (default: http://localhost:8000)
VITE_LOCAL_TTS_URL=http://localhost:8000

# --- Node.js Backend ---
PORT=3001
JWT_SECRET=change-me-to-a-random-string
NODE_ENV=development

# --- FastAPI TTS Server ---
# Comma-separated CORS origins (default: localhost only)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Docker Compose ---
FRONTEND_PORT=80
BACKEND_PORT=3001
TTS_PORT=8000

# --- Third-party API Keys (optional) ---
# ElevenLabs (set via Settings UI, stored in sessionStorage)
# ELEVENLABS_API_KEY=sk_...
# Azure Speech (set via Settings UI)
# AZURE_SPEECH_KEY=...
