# =============================================
# Voooice Environment Variables
# Copy this file to .env and fill in values
# =============================================

# --- Frontend (Vite) ---
# Local TTS server URL (default: http://localhost:8000)
VITE_LOCAL_TTS_URL=http://localhost:8000

# Sentry APM (optional – leave DSN blank to disable)
VITE_SENTRY_DSN=
VITE_APP_ENV=development
VITE_APP_VERSION=0.2.0

# --- Node.js Backend ---
PORT=3001
# CRITICAL: Set a strong random secret in production (min 64 chars)
# In development, a random key is auto-generated if not set
JWT_SECRET=
STRIPE_WEBHOOK_SECRET=
ELEVENLABS_API_KEY=
NODE_ENV=development

# --- FastAPI TTS Server ---
# Comma-separated CORS origins (default: localhost only)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Docker Compose ---
FRONTEND_PORT=80
BACKEND_PORT=3001
TTS_PORT=8000

# --- CDN & Static Assets (optional) ---
# CDN base URL for static assets (leave blank to serve locally)
CDN_URL=
# Redis URL for rate limiting and caching
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# --- S3-Compatible Object Storage (optional) ---
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# --- Third-party API Keys (optional) ---
# ElevenLabs (set via Settings UI, stored in sessionStorage)
# ELEVENLABS_API_KEY=sk_...
# Azure Speech (set via Settings UI)
# AZURE_SPEECH_KEY=...
